#!/bin/bash
# claude-mux drift guard (MANDATORY).
#
# Three generated-and-committed artifacts must each match a fresh build from source:
#   (1) claude-mux            <- src/*.sh        (make build)
#   (2) dev/CODEMAP.index.md  <- src/*.sh        (make codemap)
#   (3) dev/features/INDEX.md <- dev/features/*  (make features-index)
#
# This hook refuses any commit where any of the three is stale, catching:
#   (a) src/ edited but `make build`/`make codemap` forgotten,
#   (b) any artifact hand-edited directly (a later build silently reverts it),
#   (c) a dev/features/*.md frontmatter (lifecycle/kind) change without regenerating
#       the feature index.
#
# The index checks run UNCONDITIONALLY (not gated on which files staged): a lone
# hand-edit of a generated index, or a frontmatter-only change, must not slip past.
# Regeneration is cheap; a clean diff is a fast no-op.
#
# Install once per clone:  git config core.hooksPath .githooks
#
# If this hook rebuilds an artifact, it leaves the correct file in your working tree;
# just `git add` the named file(s) and re-commit.
#
# Known limitation (single-developer tool): `make` reads the WORKING TREE, not the git
# index, so a partially-staged src/ edit is verified against the full working tree. If
# you stage only a subset of src/ changes, rebuild + stage `claude-mux` from the same
# tree state before committing.

set -e

if ! command -v make >/dev/null 2>&1; then
    echo "pre-commit: 'make' not found; cannot verify the generated artifacts are in sync." >&2
    echo "pre-commit: install make, or run 'make check' equivalents manually, then commit." >&2
    exit 1
fi

# `make check` = build + check-codemap + check-features-index + artifact diff. Each
# sub-target regenerates into the working tree and `git diff --exit-code`s the file, so
# a stale staged copy (or a hand-edit) fails here. On failure the regenerated, correct
# files are left in the working tree for `git add`.
if ! make check >/dev/null 2>&1; then
    echo "pre-commit: BLOCKED -- a generated artifact is out of sync with source." >&2
    echo "pre-commit: the artifact(s) have been rebuilt for you. Review, then add the stale one(s):" >&2
    echo "pre-commit:     git diff --name-only           # see which were regenerated" >&2
    echo "pre-commit:     git add claude-mux dev/CODEMAP.index.md dev/features/INDEX.md" >&2
    echo "pre-commit: (Never edit generated files directly; edit src/*.sh or feature frontmatter," >&2
    echo "pre-commit:  then 'make build' / 'make codemap' / 'make features-index'.)" >&2
    # Re-run unsilenced (-k: keep going) so ALL failing files/validations are visible,
    # not just the first stale artifact.
    make check -k || true
    exit 1
fi

exit 0
