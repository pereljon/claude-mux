# ~/.claude-mux-rc — claude-mux user configuration
# Reference template. The installer (install.sh) creates ~/.claude-mux-rc automatically.
# For manual setup, copy this file to ~/.claude-mux-rc and uncomment settings to override defaults.
# This file is sourced by claude-mux at startup.

# Root directory to scan for Claude projects (directories containing .claude/).
# Default: $HOME/Claude
#BASE_DIR="$HOME/Claude"

# Directory for log files.
# Default: $HOME/Library/Logs
#LOG_DIR="$HOME/Library/Logs"

# Set Claude's permissions.defaultMode for each project via .claude/settings.local.json.
# Valid values: "" (disabled), "default", "acceptEdits", "plan", "auto", "dontAsk", "bypassPermissions"
# Default: "auto"
#DEFAULT_PERMISSION_MODE="auto"

# When true, Claude sessions can send slash commands to OTHER sessions via tmux.
# When false, sessions can only send commands to themselves.
# Enable for multi-agent orchestration workflows.
# Default: false
#ALLOW_CROSS_SESSION_CONTROL=false

# Enable tmux extended-keys for Shift+Enter and other modified key support.
# Requires tmux 3.2+. Default: true
#TMUX_EXTENDED_KEYS=true

# Seconds to wait between launching each session.
# Increase if sessions fail to register with Remote Control.
# Default: 5
#SLEEP_BETWEEN=5

# Enable/disable batch startup via LaunchAgent (-a/--all).
# When false, the LaunchAgent runs but exits without starting sessions.
# Default: true
#LAUNCHAGENT_ENABLED=true
