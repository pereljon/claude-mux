# Validate numeric tmux config values
for _var_name in SLEEP_BETWEEN TMUX_HISTORY_LIMIT TMUX_ESCAPE_TIME STAGGER_CONCURRENCY STARTING_WINDOW; do
    _var_val="${!_var_name}"
    if [[ -n "$_var_val" && ! "$_var_val" =~ ^[0-9]+$ ]]; then
