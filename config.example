# ~/.claude-mux/config - claude-mux user configuration
# Reference template. The installer (install.sh) creates ~/.claude-mux/config automatically.
# For manual setup, copy this file to ~/.claude-mux/config and uncomment settings to override defaults.
# This file is sourced by claude-mux at startup.
#
# Per-project state (hide/protect) lives in .claudemux-* marker files at each project root,
# not here. Use: claude-mux --hide, --show, --protect, --unprotect
# Run: claude-mux --config-help   to see all options with types and descriptions.

# Root directory to scan for Claude projects (directories containing .claude/).
# Default: $HOME/Claude
#BASE_DIR="$HOME/Claude"

# Directory for log files.
# Default: $HOME/Library/Logs
#LOG_DIR="$HOME/Library/Logs"

# Set Claude's permissions.defaultMode for each project via .claude/settings.local.json.
# Valid values: "" (disabled), "default", "acceptEdits", "plan", "auto", "dontAsk", "bypassPermissions"
# Default: "auto"
#DEFAULT_PERMISSION_MODE="auto"

# When true, Claude sessions can send slash commands to OTHER sessions via tmux.
# When false, sessions can only send commands to themselves.
# Default: false
#ALLOW_CROSS_SESSION_CONTROL=false

# ── tmux session options ──────────────────────────────────────────────────────

#TMUX_EXTENDED_KEYS=true           # Shift+Enter support (requires tmux 3.2+)
#TMUX_TITLE_FORMAT='#S'            # Terminal/tab title (#S = session name, "" to disable)
#TMUX_MOUSE=true                   # Mouse support (scroll, select, resize)
#TMUX_HISTORY_LIMIT=50000          # Scrollback buffer (tmux default is 2000)
#TMUX_CLIPBOARD=true               # System clipboard via OSC 52
#TMUX_DEFAULT_TERMINAL="tmux-256color"  # Terminal type for color rendering
#TMUX_ESCAPE_TIME=10               # Escape delay in ms (tmux default is 500)
#TMUX_MONITOR_ACTIVITY=true        # Activity notifications from other sessions

# ── Templates ─────────────────────────────────────────────────────────────────

# Directory containing CLAUDE.md template files.
# Default: $HOME/.claude-mux/templates
#TEMPLATES_DIR="$HOME/.claude-mux/templates"

# Default template applied to new projects (-n). Set to "" to disable.
# Default: default.md
#DEFAULT_TEMPLATE="default.md"

# ── Tips ─────────────────────────────────────────────────────────────────────

# Show a tip once per day via Stop hook (first completed turn of the day).
# When true, a Stop hook is registered in each project's settings.local.json.
# Say "enable tips" or "disable tips" to toggle. --tip always works regardless.
# Default: true
#TIP_OF_DAY=true

# Tip selection mode:
#   daily  - same tip all day (day-of-year hash) (default)
#   random - non-deterministic
#TIP_MODE=daily

# ── Update check ──────────────────────────────────────────────────────────────

# Check GitHub releases for newer versions (cached daily, TTY-only).
# Set to false to disable update notifications.
# Default: true
#UPDATE_CHECK=true

# Override binary paths if tmux/claude are not in PATH.
# Default: resolved via 'command -v' at startup
#TMUX_BIN="/path/to/tmux"
#CLAUDE_BIN="/path/to/claude"

# ── Multi-CLI-coder integration ────────────────────────────────────────────────

# Files created as symlinks pointing at CLAUDE.md so other AI CLI coders
# (Codex CLI reads AGENTS.md, Gemini CLI reads GEMINI.md, etc.) pick up
# the same project instructions. Set to empty string "" to disable.
# Default: "AGENTS.md GEMINI.md"
#MULTI_CODER_FILES="AGENTS.md GEMINI.md"

# ── LaunchAgent ───────────────────────────────────────────────────────────────

# LaunchAgent mode - what happens at login:
#   none  - do nothing
#   home  - launch a single 'home' session in $BASE_DIR (protected from shutdown) (default)
#LAUNCHAGENT_MODE=home

# Model for the home session. Set to "" to use the default model.
# Default: sonnet
#HOME_SESSION_MODEL="sonnet"

# ── Batch mode ────────────────────────────────────────────────────────────────

# Seconds to wait between launching each session.
# Default: 5
#SLEEP_BETWEEN=5
